{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.knoxmedia.vauldy",
  "description": "Vauldy desktop capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-close",
    "core:tray:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-open"
  ]
}
